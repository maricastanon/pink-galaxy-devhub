# Pink Galaxy DevHub - Production gitignore

# Large files (keep in S3)
wrap_all_files/
archinstall_pinkgalaxy/
DevHub/
*.iso
*.zip
*.tar.*

# Claude Code Settings (contains sensitive data)
.claude/
*.claude
claude-settings.json
settings.local.json

# AWS Amplify
amplify/\#current-cloud-backend
amplify/.config/local-*
amplify/logs
amplify/mock-data
amplify/mock-api-resources
amplify/backend/amplify-meta.json
amplify/backend/.temp
build/
dist/
node_modules/

# Local dev
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs
*.log